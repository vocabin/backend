# Database
DB_ROOT_PASSWORD=           # MariaDB root 비밀번호
DB_NAME=vocabin
DB_USER=vocabin
DB_PASSWORD=                # MariaDB 사용자 비밀번호

# Backend
BACKEND_PORT=8080
JWT_SECRET=                 # 32바이트 이상 랜덤 문자열 (openssl rand -base64 32)
CORS_ALLOWED_ORIGINS=       # 프론트엔드 도메인 (예: https://minu-dev.win)

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=        # 백엔드 API URL - 브라우저에서 접근 가능한 주소 (예: https://api.minu-dev.win)
